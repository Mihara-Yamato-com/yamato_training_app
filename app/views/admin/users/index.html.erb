<h1>ユーザー一覧画面</h1>

<% @users.each do |user| %>
    <div class="user">
        ユーザー名:<%= user.name %><br>
        メールアドレス :<%= user.email %><br>
        権限：<%= user.role %><br>
    </div>
    <%= button_to "編集", edit_admin_user_path(@user) , method: :GET %>
<% end %>


<p><%= button_to "ログアウト", logout_path, method: :delete %></p>
