<h1>ログイン</h1>

<%= form_with url: login_path, local: true do |f| %>

  <div class="field">
    <%= f.label :email, "メールアドレス" %><br>
    <%= f.email_field :email, autofocus: true %>
  </div>

  <div class="field">
    <%= f.label :password, "パスワード" %><br>
    <%= f.password_field :password %>
  </div>

  <div class="actions">
    <%= f.submit "ログイン" %>
  </div>

  <%= link_to "新規登録", new_user_path %>

<% end %>
            