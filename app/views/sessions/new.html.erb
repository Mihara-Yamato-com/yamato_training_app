<h1>ログイン</h1>

<%= form_with url: login_path, local: true do |f| %>
  <div class="field">
    <div class="field_column">
      <%= f.label :email, "メールアドレス" %><br>
      <%= f.email_field :email, autofocus: true, class: "button", placeholder: "example@example.com" %>
    </div>

    <div class="field_column">
      <%= f.label :password, "パスワード" %><br>
      <%= f.password_field :password, class: "button", placeholder: "comthink-pass" %>
    </div>
    </div>
    <div class="actions">
      <%= f.submit "ログイン", class: "button" %>
    </div>
  

<% end %>

<%= button_to "新規登録", new_user_path, method: :get, class: "button" %>
            